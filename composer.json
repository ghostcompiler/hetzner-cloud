{
    "name": "ghostcompiler/hetzner-cloud",
    "description": "Hetzner Cloud PHP SDK",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Ghostcompiler\\Hetzner\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ghostcompiler\\Hetzner\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "authors": [
        {
            "name": "Ghost Compiler"
        }
    ],
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    }
}
